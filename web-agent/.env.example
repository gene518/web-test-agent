# OPENAI_API_KEY: OpenAI 兼容模型服务的 API Key；使用 OpenAI 模型时通常必填。
OPENAI_API_KEY=

# OPENAI_BASE_URL: OpenAI 兼容接口基础地址；接智谱等兼容平台时填写。
OPENAI_BASE_URL=

# MASTER_MODEL: Master Agent 默认使用的模型，建议写成 `provider:model` 形式。
MASTER_MODEL=openai:gpt-4.1

# SPECIALIST_MODEL: Plan、Generator、Healer 等 Specialist Agent 默认使用的模型。
SPECIALIST_MODEL=openai:gpt-5.4

# MAX_CONVERSATION_TURNS: Master 在缺参追问流程中允许的最大用户轮次。
MAX_CONVERSATION_TURNS=20

# LLM_TIMEOUT_SECONDS: 单次模型调用的超时时间，单位秒。
LLM_TIMEOUT_SECONDS=60

# SPECIALIST_RECURSION_LIMIT: Specialist Deep Agent 执行时传给 LangGraph 的递归步数上限。
SPECIALIST_RECURSION_LIMIT=999

# LOG_LEVEL: 项目运行期日志等级，例如 INFO、DEBUG、WARNING。
LOG_LEVEL=INFO

# AGENT_DEBUG_TRACE: 是否开启本地深度调试日志。
AGENT_DEBUG_TRACE=false

# AGENT_DEBUG_FULL_MESSAGES: 是否输出完整 system/user/ai/tool 消息和最终提示词。
AGENT_DEBUG_FULL_MESSAGES=false

# AGENT_DEBUG_MAX_CHARS: 深度调试日志中单段文本的最大字符数。
AGENT_DEBUG_MAX_CHARS=4000

# PWTEST_HEADED: Playwright Test MCP 是否以有头模式启动浏览器。
PWTEST_HEADED=true

# PLAYWRIGHT_BOOTSTRAP_WORKSPACE: 启动 Playwright Test MCP 前是否自动补齐 npm 与 `@playwright/test` 依赖。
PLAYWRIGHT_BOOTSTRAP_WORKSPACE=true

# PLAYWRIGHT_TEST_PACKAGE: 自动化工程缺少 Playwright Test 依赖时执行 npm install 使用的包名或版本规格。
PLAYWRIGHT_TEST_PACKAGE=@playwright/test

# DEFAULT_AUTOMATION_PROJECT_ROOT: 自动化工程根目录；默认在用户根目录下的 `webautotest` 目录。
DEFAULT_AUTOMATION_PROJECT_ROOT=~/webautotest

# LANGSMITH_API_KEY: LangSmith API Key；开启 tracing 时填写。
LANGSMITH_API_KEY=

# LANGSMITH_PROJECT: LangSmith 项目名；用于区分不同运行环境或项目。
LANGSMITH_PROJECT=

# LANGSMITH_TRACING: 是否开启 LangSmith tracing。
LANGSMITH_TRACING=false

# PYTHONDONTWRITEBYTECODE: 是否禁止 Python 运行时生成 `.pyc` 和 `__pycache__`。
PYTHONDONTWRITEBYTECODE=1
